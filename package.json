{
  "name": "polymarket-arbitrage-trading-bot",
  "version": "1.0.0",
  "description": "Automated dump-and-hedge arbitrage bot for Polymarket 15-minute crypto markets",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node src/main.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "sim": "ts-node src/main.ts --simulation",
    "prod": "node dist/main.js --production",
    "start": "node dist/main.js",
    "backtest": "ts-node src/backtest.ts",
    "setup": "ts-node src/setup.ts"
  },
  "dependencies": {
    "@polymarket/clob-client": "^4.0.0",
    "clob-v5": "npm:@polymarket/clob-client@5.8.1",
    "@polymarket/order-utils": "^2.0.0",
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^8.0.1",
    "axios": "^1.6.0",
    "global-agent": "^3.0.0",
    "dotenv": "^16.3.1",
    "ethers": "^5.7.2",
    "express": "^5.2.1",
    "nodemailer": "^9.0.1",
    "openai": "^6.44.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
