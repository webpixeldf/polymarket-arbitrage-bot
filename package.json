{
  "name": "polymarket-arbitrage-trading-bot",
  "version": "1.0.0",
  "description": "Automated dump-and-hedge arbitrage bot for Polymarket 15-minute crypto markets",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node src/main.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "sim": "ts-node src/main.ts --simulation",
    "prod": "node dist/main.js --production",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@polymarket/clob-client": "^4.0.0",
    "@types/nodemailer": "^8.0.1",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "ethers": "^5.7.2",
    "nodemailer": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
