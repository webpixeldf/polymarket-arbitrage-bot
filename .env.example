# ============================================================
# POLYMARKET ARBITRAGE BOT — CONFIGURACAO
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no Git
# ============================================================

# --- Carteira (obrigatorio para producao) ---
PRIVATE_KEY=0xSUA_CHAVE_PRIVADA_AQUI
PROXY_WALLET_ADDRESS=0xSEU_ENDERECO_PROXY_AQUI
# 0 = EOA, 1 = Proxy, 2 = Gnosis Safe (Polymarket usa 2 por padrao)
SIGNATURE_TYPE=2

# --- Mercados a monitorar (separados por virgula) ---
# Opcoes: btc, eth, sol, xrp
MARKETS=btc,eth

# --- Polling ---
CHECK_INTERVAL_MS=1000

# --- Estrategia Dump-Hedge ---
DUMP_HEDGE_SHARES=10
# Custo combinado maximo para as duas pernas (abaixo de 1.00 = lucro garantido)
DUMP_HEDGE_SUM_TARGET=0.95
# Queda minima para detectar dump (0.15 = 15%)
DUMP_HEDGE_MOVE_THRESHOLD=0.15
# Janela de deteccao de dump (primeiros N minutos do round)
DUMP_HEDGE_WINDOW_MINUTES=5
# Forcar hedge apos N minutos (stop-loss)
DUMP_HEDGE_STOP_LOSS_MAX_WAIT_MINUTES=8

# --- Modo de operacao ---
# false = simulacao (padrao), true = producao real
PRODUCTION=false

# --- URLs das APIs (nao alterar a menos que necessario) ---
GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com

# --- Credenciais API opcionais (geradas automaticamente se DERIVE=true) ---
API_KEY=
API_SECRET=
API_PASSPHRASE=
